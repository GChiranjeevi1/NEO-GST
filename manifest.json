{
  "name": "GC Returns Pro",
  "short_name": "GC Returns Pro",
  "author": "Gaddam Chiranjeevi",
  "version": "1.3",
  "description": "Extension to quickly download GST returns from GST Portal",
  "manifest_version": 3,
  "permissions": [
    "activeTab",
    "downloads",
    "notifications",
    "tabs",
    "cookies",
    "scripting"
  ],
  "host_permissions": [
    "https://*.gst.gov.in/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://services.gst.gov.in/services/login*"],
      "js": ["login-autofill.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://services.gst.gov.in/*",
        "https://return.gst.gov.in/*"
      ],
      "js": ["contentscript.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "GC Returns Pro",
    "default_icon": {
      "16": "images/neogst-logo-16.png",
      "32": "images/neogst-logo-32.png",
      "48": "images/neogst-logo-48.png",
      "128": "images/neogst-logo-128.png"
    }
  },
  "icons": {
    "16": "images/neogst-logo-16.png",
    "32": "images/neogst-logo-32.png",
    "48": "images/neogst-logo-48.png",
    "128": "images/neogst-logo-128.png"
  }
}
